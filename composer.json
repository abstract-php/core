    "type": "library",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "AbstractLang\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Abstracts",
            "email": "developer@abstracts.one"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
